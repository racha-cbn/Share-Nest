    "@types/multer": "^2.1.0",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "pino-pretty": "^13",
    "prettier": "^3.8.3",
